# ======================= Variables de entorno del backend =======================
PORT = 5000 # Puerto
NODE_ENV = development # Entorno de desarrollo. Importa y exporta información

# ======================= Base de Datos en MySQL =======================
DB_HOST = localhost # Dirección IP
BD_PORT = 3306 # Puerto                 
DB_NAME = ecommerce_db # Nombre de la base de datos
DB_USER = root # Nombre de usuario
DB_PASSWORD = # Contraseña

# ======================= JWT WEB TOKEN =======================
JWT_SECRET = mi_clave_super_mega_hyper_secreta_2007 # Clave secreta
JMT_EXPIRES_IN = 24h # Tiempo de expiración del token

# ======================= COMFIGURACIÓN DE ARCHIVOS =======================
UPLOAD_PATH = ./uploads # Ruta de los archivos
MAX_FILE_SIZE = 5242880 #5 MB en bytes

# ======================= CORS =======================
FRONTEND_URL = http://localhost:3000
